# Public URL Street is deployed at. Used for sitemap.xml, canonical/OG tags.
NEXT_PUBLIC_SITE_URL=https://street.example.com

STREET_FIRST_BRAND_URL=https://www.seventyfouruniform.com
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_FEATURED_BRAND_LOGO_URL=

# Supabase project URL. This can be public.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only Supabase service-role key. Never expose this in browser code or send it in chat.
SUPABASE_SERVICE_ROLE_KEY=

# Used by Vercel Cron to authorize the daily catalog refresh.
CRON_SECRET=
