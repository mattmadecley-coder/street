# Public URL Street is deployed at. Used for sitemap.xml, canonical/OG tags.
NEXT_PUBLIC_SITE_URL=https://street.example.com

STREET_FIRST_BRAND_URL=https://www.seventyfouruniform.com

# Supabase project URL. This can be public.
NEXT_PUBLIC_SUPABASE_URL=

# Server-only Supabase service-role key. Never expose this in browser code or send it in chat.
SUPABASE_SERVICE_ROLE_KEY=

# Used by Vercel Cron to authorize the daily catalog refresh.
CRON_SECRET=

# Password for /admin (homepage hero, brand logos/links, product category
# overrides, analytics). Required — /admin/login refuses every attempt until
# this is set. Pick something long and random; there's no username, just this.
ADMIN_PASSWORD=

# Homepage hero image/video and the featured-brand spotlight are no longer
# env vars — they're editable at /admin/homepage (stored in the site_settings
# table) so they can change without a redeploy.
